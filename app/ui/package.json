{
  "name": "kiosco-cinemex-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.3.1",
    "@blueprintjs/icons": "^6.1.0",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.3",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.jaguar.kiosco.cinemex",
    "productName": "KioscoCinemex",
    "directories": { "output": "release" },
    "files": ["dist/**", "electron/**", "package.json"],
    "extraResources": [
      {
        "from": "../",
        "to": "backend",
        "filter": [
          "main.py",
          "settings.py",
          "logging_setup.py",
          "config_loader.py",
          "api_routes.py",
          "pyproject.toml",
          "core/**/*",
          "services/**/*",
          "config/**/*"
        ]
      }
    ],
    "win": { "target": ["nsis"] }
  }
}
