CPI_HOST=
CPI_PORT=5000
CPI_CLIENT_ID=
CPI_CLIENT_SECRET=
CPI_USERNAME=
CPI_PASSWORD=
# PEM con la CA del CPI (p. ej. certificado_cpi.crt en la raíz del repo). Ruta absoluta o relativa
# al cwd, a app/ o al directorio padre de app/ (raíz KIOSCO-CINEMEX).
# Vacío → bundle por defecto de Python (suele fallar si el CPI usa CA propia).
CPI_CA_BUNDLE=certificado_cpi.crt
# Solo desarrollo: true omite verificación del Root.cer en el almacén Windows (no usar en kiosco).
CPI_ALLOW_WITHOUT_ROOT_VERIFICATION=false

IM30_HOST=localhost
IM30_PORT=6000
IM30_USER=
IM30_PASSWORD=
EMV_BRIDGE_TOKEN=

# Ruta absoluta al python.exe que debe usar Electron (spawn de main.py).
# Desarrollo con venv: ...\KIOSCO-CINEMEX\app\.venv\Scripts\python.exe
# Kiosco: p. ej. C:\Python311\python.exe
PYTHON_PATH=

MQTT_BROKER_URL=
# Vacío u omitido → 1883 (integración MQTT aún no activa en el PRD).
MQTT_PORT=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_BASE=